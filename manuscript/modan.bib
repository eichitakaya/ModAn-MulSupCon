	month = may,
	year = {2023},
	note = {arXiv:2212.07677 [cs]},
	keywords = {Computer Science - Machine Learning, Computer Science - Artificial Intelligence, Computer Science - Computation and Language},
	annote = {In-context learningが勾配降下法と等価であることを示した
},
	file = {Oswald et al. - 2023 - Transformers learn in-context by gradient descent.pdf:C\:\\Users\\takay\\Zotero\\storage\\JJRSXIYU\\Oswald et al. - 2023 - Transformers learn in-context by gradient descent.pdf:application/pdf},
