@inproceedings{nehary_comparison_2023,
	address = {Ottawa, ON, Canada},
	title = {Comparison of {COVID}-19 {Classification} via {Imagenet}-{Based} and {RadImagenet}-{Based} {Transfer} {Learning} {Models} with {Random} {Frame} {Selection}},
