	editor = {Wang, Linwei and Dou, Qi and Fletcher, P. Thomas and Speidel, Stefanie and Li, Shuo},
	year = {2022},
	doi = {10.1007/978-3-031-16437-8_6},
	note = {Series Title: Lecture Notes in Computer Science},
	pages = {55--64},
	file = {You et al. - 2022 - Intra-class Contrastive Learning Improves Computer.pdf:C\:\\Users\\takay\\Zotero\\storage\\97BQVPRZ\\You et al. - 2022 - Intra-class Contrastive Learning Improves Computer.pdf:application/pdf},
