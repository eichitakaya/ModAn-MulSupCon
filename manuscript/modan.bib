	year = {2022},
	doi = {10.1007/978-3-031-16437-8_16},
	note = {Series Title: Lecture Notes in Computer Science},
	pages = {163--174},
	file = {Li et al. - 2022 - SATr Slice Attention with Transformer for Univers.pdf:C\:\\Users\\takay\\Zotero\\storage\\LXS5BUCL\\Li et al. - 2022 - SATr Slice Attention with Transformer for Univers.pdf:application/pdf},
