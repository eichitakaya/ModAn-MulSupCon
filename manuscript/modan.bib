@article{zhang_deeprecs_2022,
	title = {{DeepRecS}: {From} {RECIST} {Diameters} to {Precise} {Liver} {Tumor} {Segmentation}},
	volume = {26},
	issn = {2168-2194, 2168-2208},
	shorttitle = {{DeepRecS}},
