}

@article{lee_multiagent_2007,
	title = {A {Multiagent} {Approach} to \${Q}\$-{Learning} for {Daily} {Stock} {Trading}},
	volume = {37},
	issn = {1083-4427},
	url = {http://ieeexplore.ieee.org/document/4342801/},
