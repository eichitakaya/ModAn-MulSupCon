	keywords = {Computer Science - Computer Vision and Pattern Recognition, Computer Science - Machine Learning, Computer Science - Artificial Intelligence},
	annote = {ラベル分布を用いてマルチラベル学習の性能を向上させる。
ラベル分布は、画像特徴の類似度をもとに算出する。（似ている画像同士が同じラベルを持つように）
},
	file = {PDF:C\:\\Users\\takay\\Zotero\\storage\\J3C3QU4W\\Chen et al. - 2025 - Improving Multi-Label Contrastive Learning by Leveraging Label Distribution.pdf:application/pdf},
