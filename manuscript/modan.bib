	file = {Mei et al. - 2022 - RadImageNet An Open Radiologic Deep Learning Rese.pdf:C\:\\Users\\takay\\Zotero\\storage\\RYFFEZIY\\Mei et al. - 2022 - RadImageNet An Open Radiologic Deep Learning Rese.pdf:application/pdf},
