	author = {Nguyen, Duy M. H. and Nguyen, Hoang and Diep, Nghiem T. and Pham, Tan N. and Cao, Tri and Nguyen, Binh T. and Swoboda, Paul and Ho, Nhat and Albarqouni, Shadi and Xie, Pengtao and Sonntag, Daniel and Niepert, Mathias},
	month = nov,
