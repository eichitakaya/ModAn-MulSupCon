	keywords = {Computer Science - Machine Learning, Computer Science - Artificial Intelligence, Computer Science - Computation and Language},
	annote = {Comment: 18 pages; 10 figures. Published as a conference paper at EMNLP 2023 Findings (Long Paper). Code and data available at https://github.com/simonucl/HJCL},
	annote = {マルチラベルかつ階層構造をもつデータを前提。グラフニューラルネットで埋込表現を学習し、そのベクトルを用いて対照学習。
},
	file = {PDF:C\:\\Users\\takay\\Zotero\\storage\\LE2S5RW7\\Yu et al. - 2024 - Instances and Labels Hierarchy-aware Joint Supervised Contrastive Learning for Hierarchical Multi-L.pdf:application/pdf},
