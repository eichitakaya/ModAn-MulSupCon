@inproceedings{rigoll_segmentation_nodate,
	title = {Segmentation of {SBFSEM} {Volume} {Data} of {Neural} {Tissue} by {Hierarchical} {Classification}},
	volume = {5096},
	isbn = {978-3-540-69320-8 978-3-540-69321-5},
	url = {http://link.springer.com/10.1007/978-3-540-69321-5_15},
	abstract = {Three-dimensional electron-microscopic image stacks with almost isotropic resolution allow, for the ﬁrst time, to determine the complete connection matrix of parts of the brain. In spite of major advances in staining, correct segmentation of these stacks remains challenging, because very few local mistakes can lead to severe global errors. We propose a hierarchical segmentation procedure based on statistical learning and topology-preserving grouping. Edge probability maps are computed by a random forest classiﬁer (trained on hand-labeled data) and partitioned into supervoxels by the watershed transform. Over-segmentation is then resolved by another random forest. Careful validation shows that the results of our algorithm are close to human labelings.},
	language = {en},
	urldate = {2020-07-05},
	booktitle = {Pattern {Recognition}. {DAGM2008}, {Lecture} {Notes} in {Computer} {Science}},
