	editor = {Wang, Linwei and Dou, Qi and Fletcher, P. Thomas and Speidel, Stefanie and Li, Shuo},
	year = {2022},
	doi = {10.1007/978-3-031-16443-9_50},
	note = {Series Title: Lecture Notes in Computer Science},
	pages = {517--526},
	file = {Wang et al. - 2022 - SMESwin Unet Merging CNN and Transformer for Medi.pdf:C\:\\Users\\takay\\Zotero\\storage\\LRW7BJTQ\\Wang et al. - 2022 - SMESwin Unet Merging CNN and Transformer for Medi.pdf:application/pdf},
