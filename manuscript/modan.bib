	note = {Series Title: Lecture Notes in Computer Science},
	pages = {57--66},
	file = {Zhu et al. - 2022 - Aggregative Self-supervised Feature Learning from .pdf:C\:\\Users\\takay\\Zotero\\storage\\F94E4G6F\\Zhu et al. - 2022 - Aggregative Self-supervised Feature Learning from .pdf:application/pdf},
