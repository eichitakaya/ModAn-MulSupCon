	file = {Ciresan et al. - Deep Neural Networks Segment Neuronal Membranes in.pdf:C\:\\Users\\takay\\Zotero\\storage\\9SB88LLN\\Ciresan et al. - Deep Neural Networks Segment Neuronal Membranes in.pdf:application/pdf},
}

