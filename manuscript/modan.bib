	journal = {Computers, Materials \& Continua},
	author = {M. Ameen Suhail, K. and Sankar, Syam and S. Kumar, Ashok and Nestor, Tsafack and F. Soliman, Naglaa and D. Algarni, Abeer and El-Shafai, Walid and E. Abd El-Samie, Fathi},
	year = {2022},
