	pages = {113--147},
	file = {Lussange et al. - 2021 - Modelling Stock Markets by Multi-agent Reinforceme.pdf:C\:\\Users\\takay\\Zotero\\storage\\2FVZZQPU\\Lussange et al. - 2021 - Modelling Stock Markets by Multi-agent Reinforceme.pdf:application/pdf},
}

@article{li_deep_2019,
	title = {Deep {Robust} {Reinforcement} {Learning} for {Practical} {Algorithmic} {Trading}},
	volume = {7},
	issn = {2169-3536},
