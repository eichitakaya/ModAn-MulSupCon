	month = dec,
	year = {2023},
	pages = {1373--1388},
	file = {Hamabuchi et al. - 2023 - Effectiveness of deep learning reconstruction on s.pdf:C\:\\Users\\takay\\Zotero\\storage\\DI4QRIMB\\Hamabuchi et al. - 2023 - Effectiveness of deep learning reconstruction on s.pdf:application/pdf},
