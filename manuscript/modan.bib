	editor = {Martel, Anne L. and Abolmaesumi, Purang and Stoyanov, Danail and Mateus, Diana and Zuluaga, Maria A. and Zhou, S. Kevin and Racoceanu, Daniel and Joskowicz, Leo},
	year = {2020},
	doi = {10.1007/978-3-030-59710-8_14},
	note = {Series Title: Lecture Notes in Computer Science},
	pages = {137--147},
	file = {Haghighi et al. - 2020 - Learning Semantics-Enriched Representation via Sel.pdf:C\:\\Users\\takay\\Zotero\\storage\\HZ29EPXW\\Haghighi et al. - 2020 - Learning Semantics-Enriched Representation via Sel.pdf:application/pdf},
