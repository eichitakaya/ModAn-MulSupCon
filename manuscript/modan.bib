	year = {2021},
	doi = {10.1007/978-3-030-87234-2_8},
	note = {Series Title: Lecture Notes in Computer Science},
	pages = {78--87},
	file = {Ouyang et al. - 2021 - Self-adversarial Learning for Detection of Cluster.pdf:C\:\\Users\\takay\\Zotero\\storage\\8EXN6ZRS\\Ouyang et al. - 2021 - Self-adversarial Learning for Detection of Cluster.pdf:application/pdf},
